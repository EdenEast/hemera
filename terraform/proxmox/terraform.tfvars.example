# Copy to terraform.tfvars and replace every TODO_CONFIRM value locally.
# terraform.tfvars is gitignored because it contains environment-specific and
# potentially sensitive Proxmox details.

proxmox_endpoint     = "https://TODO_CONFIRM:8006/"
proxmox_api_token    = "USER@REALM!TOKENID=TOKEN_SECRET"
proxmox_insecure     = true
proxmox_node_name    = "TODO_CONFIRM_THOR_NODE_NAME"
nixos_template_id    = 9000
proxmox_datastore_id = "TODO_CONFIRM_DATASTORE"
proxmox_bridge       = "vmbr0"
