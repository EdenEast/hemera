#!/usr/bin/env bash
set -euo pipefail

control_plane_ip="${CONTROL_PLANE_IP:-192.168.2.81}"
ssh_user="${SSH_USER:-admin}"
kubeconfig="${KUBECONFIG:-$PWD/generated/kubeconfig}"

mkdir -p "$(dirname "$kubeconfig")"

ssh "${ssh_user}@${control_plane_ip}" 'sudo cat /etc/rancher/k3s/k3s.yaml' \
  | sed "s#https://127.0.0.1:6443#https://${control_plane_ip}:6443#g" \
  >"$kubeconfig"

chmod 0600 "$kubeconfig"
echo "Wrote $kubeconfig"
