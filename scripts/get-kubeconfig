#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/lib/cluster-nodes.sh
source "$script_dir/lib/cluster-nodes.sh"

control_plane="k8s-cp-01"
control_plane_ip="$(cluster_node_ip "$control_plane")"
target="$(cluster_node_target "$control_plane")"
output_path="${HEMERA_KUBECONFIG:-generated/kubeconfig}"
remote_path="/etc/rancher/k3s/k3s.yaml"

if ! command -v ssh >/dev/null 2>&1; then
  echo "ssh is required to retrieve kubeconfig" >&2
  exit 1
fi

mkdir -p "$(dirname "$output_path")"

if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$target" sudo test -r "$remote_path"; then
  echo "cannot read $remote_path from $target" >&2
  echo "confirm the control-plane Cluster Node is reachable and k3s is running" >&2
  exit 1
fi

# remote_path is intentionally expanded locally before invoking ssh.
# shellcheck disable=SC2029
ssh "$target" sudo cat "$remote_path" |
  sed "s#https://127.0.0.1:6443#https://$control_plane_ip:6443#g" \
    >"$output_path"

chmod 0600 "$output_path"

echo "wrote $output_path"
echo "use: export KUBECONFIG=$PWD/$output_path"
